{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2018",
    "allowJs": false,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "isolatedModules": true,
    "strict": true,
    "lib": [
      "DOM",
      "ES2018"
    ]
  },
  "include": [
    "main.ts",
    "style-editor-modal.ts",
    "view.ts",
    "settings.ts",
    "types.ts",
    "theme.ts",
    "normalize.ts",
    "render-preview.ts",
    "render-export.ts",
    "sanitize.ts",
    "clipboard.ts",
    "renderer.ts"
  ],
  "exclude": [
    "node_modules",
    "vscode-markdown-to-wechat-master",
    "fixtures"
  ]
}
